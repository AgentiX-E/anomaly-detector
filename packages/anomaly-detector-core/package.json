{
  "name": "@agentix-e/anomaly-detector-core",
  "version": "1.0.0",
  "description": "Core anomaly detection engine for time-series \u2014 RRCF detection, multi-model forecasting, attribution, and drift detection. Works in Node.js and Browser.",
  "keywords": [
    "time-series",
    "anomaly-detection",
    "forecasting",
    "rrcf",
    "trcf",
    "aiops",
    "monitoring",
    "typescript",
    "agentix-e",
    "wasm",
    "browser"
  ],
  "license": "MIT",
  "author": "AgentiX-E",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AgentiX-E/anomaly-detector",
    "directory": "packages/anomaly-detector-core"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./detect": {
      "types": "./dist/detect/index.d.ts",
      "import": "./dist/detect/index.js",
      "require": "./dist/detect/index.cjs"
    },
    "./forecast": {
      "types": "./dist/forecast/index.d.ts",
      "import": "./dist/forecast/index.js",
      "require": "./dist/forecast/index.cjs"
    },
    "./calibrate": {
      "types": "./dist/calibrate/index.d.ts",
      "import": "./dist/calibrate/index.js",
      "require": "./dist/calibrate/index.cjs"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js",
      "require": "./dist/utils/index.cjs"
    },
    "./visualize": {
      "types": "./dist/visualize/index.d.ts",
      "import": "./dist/visualize/index.js",
      "require": "./dist/visualize/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "lint": "eslint src/ --ext .ts",
    "typecheck": "tsc --noEmit",
    "bench": "vitest bench",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@beshu-tech/trcf-ts": "^1.1.0",
    "@sipemu/anofox-forecast": "^0.15.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "@vitest/browser": "^3.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
