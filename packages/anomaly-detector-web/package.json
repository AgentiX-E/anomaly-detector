{
  "name": "@agentix-e/anomaly-detector-web",
  "version": "0.0.0",
  "description": "Browser entry for anomaly-detector \u2014 adds TimesFM foundation-model forecasting via ONNX Runtime Web. TimesFM is opt-in \u2014 install @agentix-e/timesfm-web separately.",
  "keywords": [
    "time-series",
    "anomaly-detection",
    "forecasting",
    "timesfm",
    "onnx",
    "wasm",
    "webgpu",
    "aiops",
    "typescript",
    "agentix-e",
    "browser"
  ],
  "license": "MIT",
  "author": "AgentiX-E",
  "repository": {
    "type": "git",
    "url": "https://github.com/AgentiX-E/anomaly-detector",
    "directory": "packages/anomaly-detector-web"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "lint": "eslint src/ --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@agentix-e/anomaly-detector-core": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "@vitest/browser": "^3.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
