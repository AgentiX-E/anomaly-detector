{
  "name": "anomaly-detector-monorepo",
  "private": true,
  "description": "Embedded time-series anomaly detection engine — dual-runtime (Node.js + Browser), RRCF streaming, 40+ forecasting models, TimesFM foundation model, Shapley attribution",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r dev",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "bench": "pnpm -r bench",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish",
    "clean": "pnpm -r clean"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^9.0.0",
    "playwright": "^1.61.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.64.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.0.0",
  "dependencies": {
    "@agentix-e/timesfm-core": "1.0.0"
  },
  "keywords": [
    "anomaly-detection",
    "time-series",
    "forecasting",
    "rrcf",
    "timesfm",
    "machine-learning",
    "streaming",
    "typescript",
    "browser",
    "nodejs",
    "aiops",
    "monitoring"
  ]
}
